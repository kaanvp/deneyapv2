# Supabase veya herhangi bir PostgreSQL bağlantı adresi
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Önemli: Supabase size 'postgres://' verirse kod bunu otomatik 'postgresql://' yapar.
DATABASE_URL=postgresql://postgres:[SIFRENIZ]@[HOST-ADRESI].supabase.co:5432/postgres

# JWT Güvenliği için gizli anahtar (Değiştirmeyi unutmayın!)
SECRET_KEY=buraya_cok_gizli_bir_anahtar_yazin
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Supabase Storage (Görsel yükleme için)
SUPABASE_URL=https://[PROJE-ID].supabase.co
SUPABASE_KEY=ey... (service_role_key tavsiye edilir)
SUPABASE_BUCKET=product-images
